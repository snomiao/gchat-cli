{
  "name": "gchat-cli",
  "version": "0.1.0",
  "description": "Google Chat CLI — list spaces, read / send / tail messages, resolve space names, with a send confirm-guard.",
  "repository": {
    "type": "git",
    "url": "https://github.com/snomiao/gchat-cli.git"
  },
  "bugs": {
    "url": "https://github.com/snomiao/gchat-cli/issues"
  },
  "homepage": "https://github.com/snomiao/gchat-cli",
  "keywords": ["google-chat", "gchat", "cli", "messaging", "agent", "terminal"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "gchat": "./ts/cli.ts"
  },
  "files": ["ts/", "dist/", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "gchat": "./dist/cli.js"
    }
  },
  "scripts": {
    "dev": "bun run ts/cli.ts",
    "build": "bun build ts/cli.ts --target=node --outfile dist/cli.js --minify",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "gchat": "bun ts/cli.ts",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13",
    "@semantic-release/github": "^12",
    "@semantic-release/npm": "^13",
    "@semantic-release/release-notes-generator": "^14",
    "@types/bun": "latest",
    "@types/node": "^22",
    "@types/yargs": "^17.0.35",
    "semantic-release": "^24",
    "typescript": "^5.6"
  },
  "overrides": {
    "@semantic-release/npm": "^13",
    "@semantic-release/github": "^12"
  }
}
